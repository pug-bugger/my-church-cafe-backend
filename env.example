PORT=4000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=church_cafe

JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d

# CORS allowed origins for both REST + Socket.IO
# - unset or "*" means allow any origin (dev-friendly)
# - set to one origin: CORS_ORIGIN=http://localhost:3000
# - set multiple: CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
CORS_ORIGIN=http://localhost:3000

# Max size (MB) for product + user image uploads (multer). Default 15, max 50.
# If you still get 413 before Node sees the request, raise your reverse proxy limit, e.g. nginx:
#   client_max_body_size 20M;
UPLOAD_MAX_IMAGE_MB=15

